FROM node:22-alpine

WORKDIR /app

# Instala dependências básicas para o Prisma e saúde do container
RUN apk add --no-cache openssl

# Copia arquivos de dependências
COPY package*.json ./
COPY prisma ./prisma/

# Instala todas as dependências (incluindo devDependencies para testes e watch mode)
RUN npm install

# Copia o restante do código (será sobrescrito pelo volume em dev, mas útil para o build inicial)
COPY . .

# Gera o Prisma Client
RUN npx prisma generate

# Comando para rodar testes e depois iniciar em modo watch
CMD ["sh", "-c", "npm run test && npm run start:dev"]
